# ---- Ports (scanned free on this machine) ----
WEB_PORT=5290
API_PORT=4310
PG_PORT=5440
KAFKA_PORT=9292
LOCALSTACK_PORT=4576
COMPOSE_PROJECT_NAME=image-validator

# ---- Postgres ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=image_validator
DATABASE_URL=postgresql://postgres:postgres@localhost:5440/image_validator?schema=public

# ---- Kafka ----
KAFKA_BROKERS=localhost:9292
KAFKA_CLIENT_ID=image-validator

# ---- S3 (LocalStack) ----
S3_ENDPOINT=http://localhost:4576
S3_REGION=us-east-1
S3_BUCKET=images
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ---- App ----
API_PORT=4310
API_PUBLIC_URL=http://localhost:4310
